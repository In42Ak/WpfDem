<Window x:Class="WpfDem.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfDem"
        mc:Ignorable="d"
        Title="Авторизация" Height="450" Width="800"
        Background="White"
        Icon="/Res/icon.ico">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Background="#7FFF00">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Image Source="/Res/Icon.png" Height="60" Margin="20 10"
                   Stretch="Uniform" HorizontalAlignment="Left"/>
            <TextBlock Grid.Column="1" Text="Авторизация"
                       VerticalAlignment="Center" Margin="20 0" FontWeight="Bold"/>
        </Grid>

        <StackPanel Grid.Row="1" Margin="60" VerticalAlignment="Center">
            <TextBox Name="LoginEnter" Margin="20 10"/>
            <PasswordBox Name="PasswordEnter" Margin="20 10"/>
            <Button Name="LoginButton" Content="Войти" Margin="40 20" Click="LoginButton_Click"/>
            <TextBlock HorizontalAlignment="Center" Text="Войти как гость"
                       Foreground="DimGray" MouseDown="TextBlock_MouseDown"/>
        </StackPanel>
    </Grid>
</Window>