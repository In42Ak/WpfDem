<Window x:Class="WpfDem.ProductWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfDem"
        mc:Ignorable="d"
        Title="Продукты" Height="800" Width="1200"
        Background="White"
        Icon="/Res/Icon.png">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="50"/>
        </Grid.RowDefinitions>

        <Grid Background="#7FFF00">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Image Source="/Res/Icon.png" Height="60" Margin="20 10"
                   Stretch="Uniform" HorizontalAlignment="Left"/>
            <TextBlock Grid.Column="1" Text="Продукты"
                       VerticalAlignment="Center" Margin="20 0" FontWeight="Bold"/>
            <StackPanel Grid.Column="2" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="20 10">
                <TextBlock Name="FullUserName" HorizontalAlignment="Right"/>
                <TextBlock Name="FullUserRole" HorizontalAlignment="Right" FontSize="14"/>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1" Name="AdminPanel" Background="#7FFF00">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <StackPanel Margin="20 10" Grid.Column="0">
                <TextBlock Text="Поиск:"/>
                <TextBox Name="SearchingTextbox" TextChanged="SearchingTextbox_TextChanged"/>
            </StackPanel>
            <StackPanel Margin="20 10" Grid.Column="1">
                <TextBlock Text="Сортировка:"/>
                <ComboBox Name="SortingCombobox" SelectionChanged="SortingCombobox_SelectionChanged"/>
            </StackPanel>
            <StackPanel Margin="20 10" Grid.Column="2">
                <TextBlock Text="Фильтрация:"/>
                <ComboBox Name="FilteringCombobox" SelectionChanged="FilteringCombobox_SelectionChanged"/>
            </StackPanel>
        </Grid>

        <ScrollViewer Grid.Row="2">
            <ItemsControl Name="ProductList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="10" Tag="{Binding Id}" Background="{Binding Background}"
                                MouseDown="Border_MouseDown"
                                BorderBrush="Gray" BorderThickness="1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="120"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" Width="120" Height="120" Margin="10"
                                        BorderBrush="Gray" BorderThickness="1">
                                    <Image Source="{Binding Photo}" Stretch="Uniform"/>
                                </Border>

                                <StackPanel Grid.Column="1" Margin="10" VerticalAlignment="Center">
                                    <TextBlock FontWeight="Bold">
                                        <Run Text="{Binding Category.Name}"/>
                                        <Run Text=" | "/>
                                        <Run Text="{Binding Name}"/>
                                    </TextBlock>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Описание: "/>
                                        <TextBlock Text="{Binding Description}" TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Производитель: "/>
                                        <TextBlock Text="{Binding Producer.Name}"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Поставщик: "/>
                                        <TextBlock Text="{Binding Provider.Name}"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Цена: "/>
                                        <TextBlock Text="{Binding Price, StringFormat=C2}"/>
                                        <TextBlock Text="   "/>
                                        <TextBlock Text="{Binding OldPrice, StringFormat=C2}" Foreground="Red" TextDecorations="Strikethrough"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Единица измерения: "/>
                                        <TextBlock Text="{Binding Unit.Name}"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Количество на складе: "/>
                                        <TextBlock Text="{Binding StockQuantity}"/>
                                    </StackPanel>
                                </StackPanel>

                                <Border Grid.Column="2" BorderBrush="Gray" BorderThickness="1"
                                        Margin="5" VerticalAlignment="Stretch">
                                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                        <TextBlock Text="Действующая" HorizontalAlignment="Center" FontSize="14"/>
                                        <TextBlock Text="скидка" HorizontalAlignment="Center" FontSize="14"/>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                            <TextBlock Text="{Binding Discount}" FontWeight="Bold"/>
                                            <TextBlock Text=" %" FontWeight="Bold"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <Grid Grid.Row="3" Background="#7FFF00">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Button Name="LogoutButton" Content="Выход" Grid.Column="0"
                    VerticalAlignment="Center" Margin="20 0" Click="LogoutButton_Click"/>
            <Button Name="OrdersButton" Content="Заказы" Grid.Column="2"
                    VerticalAlignment="Center" Margin="10 0" Click="OrdersButton_Click"/>
            <Button Name="CreateButton" Content="Создать" Grid.Column="3" Visibility="Collapsed"
                    VerticalAlignment="Center" Margin="20 0" Click="CreateButton_Click"/>
        </Grid>
    </Grid>
</Window>